# Opelo runs entirely in mock/demo mode without any of these. No auth.

# Primary LLM (Gemini — Google DeepMind sponsor)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional LLM fallbacks (used only if GEMINI_API_KEY is missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Phone / SMS via AgentPhone
AGENTPHONE_API_KEY=
AGENTPHONE_BASE_URL=https://api.agentphone.ai/v1
AGENTPHONE_NUMBER=
# Optional: override send path if your AgentPhone tenant uses a different
# endpoint shape (default `/sms/send` relative to AGENTPHONE_BASE_URL).
AGENTPHONE_SEND_PATH=
OWNER_PHONE_NUMBER=

# Email via AgentMail (required for live send)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_BASE_URL=https://api.agentmail.to/v0

# Payments via Sponge
SPONGE_API_KEY=
SPONGE_BASE_URL=

# Company memory via Supermemory
SUPERMEMORY_API_KEY=

# Calendar
GOOGLE_CALENDAR_ID=

NEXT_PUBLIC_DEMO_MODE=true
