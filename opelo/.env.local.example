# Opelo runs entirely in mock/demo mode without any of these. No auth.
# Provide an LLM key to swap the deterministic engine's copy for warmer drafts.

# LLM: OpenAI is preferred if both are set. Defaults to gpt-4o-mini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional fallback if you have an Anthropic key instead
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Email (mock unless set)
AGENTMAIL_API_KEY=

# Phone / SMS via AgentPhone (mock unless set)
AGENTPHONE_API_KEY=
AGENTPHONE_BASE_URL=
AGENTPHONE_NUMBER=
OWNER_PHONE_NUMBER=

# Payments via Sponge (mock unless set)
SPONGE_API_KEY=
SPONGE_BASE_URL=

# Calendar (mock unless set)
GOOGLE_CALENDAR_ID=

# Optional: Supabase persistence (local JSON store is used when missing)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
